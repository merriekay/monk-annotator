# Copy this file to .env and fill in real values. .env is gitignored.

# Required. Kaggle -> Settings -> API -> "Create New Token". Also make sure
# your Kaggle account has accepted FSboard's dataset terms at
# https://www.kaggle.com/datasets/googleai/fsboard
KAGGLE_API_TOKEN=

# Only used by `npm start` (server/index.js), the standalone production
# server -- not by `npm run dev`. If the server is reachable beyond your own
# machine, set both to gate it behind HTTP Basic Auth. Leave blank to disable
# auth (fine for strictly local/private use).
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=

# Only used by `npm start`. Defaults to 8080.
PORT=
